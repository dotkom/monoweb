{
  "name": "@dotkomonline/grades-db",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./schemas": {
      "import": "./src/schemas.ts",
      "types": "./src/schemas.ts"
    },
    "./test-harness": {
      "import": "./src/test-harness.ts",
      "types": "./src/test-harness.ts"
    }
  },
  "scripts": {
    "lint": "biome check . --write",
    "lint-check": "biome check .",
    "type-check": "tsc --noEmit",
    "prisma": "prisma",
    "migrate": "prisma migrate dev",
    "generate": "prisma generate --sql && node -e \"const fs=require('fs'),f='generated/schema/index.ts';fs.writeFileSync(f,'// @ts-nocheck\\n'+fs.readFileSync(f,'utf8'))\"",
    "apply-fixtures": "tsx src/fixtures.ts"
  },
  "dependencies": {
    "@dotkomonline/logger": "workspace:*",
    "@dotkomonline/utils": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@testcontainers/postgresql": "^11.5.1",
    "date-fns": "^4.1.0",
    "pg": "^8.16.0",
    "prisma-zod-generator": "^2.1.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@dotkomonline/config": "workspace:*",
    "@types/common-tags": "1.8.4",
    "@types/node": "22.19.7",
    "@types/pg": "8.20.0",
    "common-tags": "1.8.2",
    "prisma": "7.8.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
